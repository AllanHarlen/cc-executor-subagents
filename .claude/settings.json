{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(node:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(kubectl delete namespace:*)",
      "Bash(drop database:*)",
      "Bash(format *)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(kubectl apply:*)",
      "Bash(openspec publish:*)"
    ]
  }
}
